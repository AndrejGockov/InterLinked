@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container-fluid p-5 m-3 d-flex justify-content-center align-items-center">
    <div class="container border-2 p-3 shadow-sm rounded-1 w-50">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div class="container mb-3 pb-3 text-center align-items-center">
                <h1 class="fw-bold">Join Linker</h1>
                <hr />
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" placeholder="" />
                <label asp-for="Input.UserName">Username</label>
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-floating mb-4">
                <select asp-for="Input.organizationType" class="form-select"
                        asp-items="Html.GetEnumSelectList<InterLinked.Models.InterlinkedAppUser.UserType>()">
                </select>
                <label asp-for="Input.organizationType">Account Type</label>
                <span asp-validation-for="Input.organizationType" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-center mt-3">
                <button id="registerSubmit" type="submit" class="w-50 btn btn-lg btn-primary">Register</button>
            </div>

            <div class="mt-3 mb-4 text-center">
                <div class="d-flex align-items-center justify-content-center mt-4">
                    <hr class="flex-grow-1 border-0 border-top border-dark" style="border-top-style: solid !important;">
    
                    <p class="mx-3" style="font-size: 14px; position: relative; bottom: -1px;">or</p>
    
                    <hr class="flex-grow-1 border-0 border-top border-dark" style="border-top-style: solid !important;">
                </div>

                <p class="mt-3 pt-3">Already on Linker? <a href="/Identity/Account/Login">Sign in</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
