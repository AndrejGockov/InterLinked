@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post" enctype="multipart/form-data">
            @* Visual feedback if things fail *@
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>
            
            @* HIDDEN FIELD: This satisfies the 'required' property in your User model *@
            <input type="hidden" asp-for="Input.OrganizationType" />

            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" />
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Input.CompanyDescription" class="form-control" style="height: 120px"></textarea>
                <label asp-for="Input.CompanyDescription" class="form-label"></label>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ProfilePicture" class="form-label">Profile Logo</label>
                <input asp-for="Input.ProfilePicture" type="file" class="form-control" accept="image/*" />
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-primary">Save Changes</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
