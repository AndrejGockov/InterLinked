@model IEnumerable<InterLinked.Models.Application>

@{
    ViewData["Title"] = "Applicants";
}

<h1>Applicants to My Posts</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Post</th>
            <th>Applicant</th>
            <th>Email</th>
            <th>Applied At</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Post?.Title</td>

                <td>@item.User?.UserName</td>

                <td>@item.User?.Email</td>

                <td>@item.AppliedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
    </tbody>
</table>