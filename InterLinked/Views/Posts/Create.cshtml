@model InterLinked.Models.Post

@{
    ViewData["Title"] = "Create Post";
}

<div class="container mt-4" style="max-width: 800px;">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Create a new company post</h2>
        <p class="text-muted mb-0">Enter the details below and click "Create new post" to create the new post!</p>
    </div>

    <!-- CARD -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- TITLE -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Post title</label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <!-- VALID TO -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="ValidTo" class="form-label fw-semibold">
                            Position open until:
                        </label>
                        <input asp-for="ValidTo" class="form-control" />
                        <span asp-validation-for="ValidTo" class="text-danger"></span>
                    </div>
                </div>

                <!-- WEBSITE -->
                <div class="mb-4">
                    <label asp-for="WebsiteLink" class="form-label fw-semibold">
                        External link to this position
                    </label>
                    <input asp-for="WebsiteLink" class="form-control" />
                    <span asp-validation-for="WebsiteLink" class="text-danger"></span>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-between align-items-center">

                    <a asp-action="Index" class="btn btn-link text-decoration-none">
                        ← Back
                    </a>

                    <button type="submit" class="btn btn-primary px-3">
                        Create new post
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}