@model InterLinked.Models.Post

@{
    ViewData["Title"] = "Create Post";

    var validToDate = ViewBag.ValidToDate as string ?? "";
}

<div class="container mt-4" style="max-width: 800px;">

    <!-- TOP LEFT BACK BUTTON -->
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-link text-decoration-none"
               onclick="return confirm('Are you sure you want to discard changes?')">
            ← Back
        </a>
    </div>

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Create a new company post</h2>
        <p class="text-muted mb-0">
            Enter the details below and click "Create new post"
        </p>
    </div>

    <!-- CARD -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- TITLE -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Post title</label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- WEBSITE -->
                <div class="mb-4">
                    <label asp-for="WebsiteLink" class="form-label fw-semibold">
                        External URL
                    </label>
                    <input asp-for="WebsiteLink" class="form-control" />
                    <span asp-validation-for="WebsiteLink" class="text-danger"></span>
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- OPEN UNTIL DATE -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Post will be open until:
                    </label>

                    <input type="date"
                           name="ValidToDate"
                           class="form-control"
                           value="@validToDate" />

                    <span class="text-danger">
                        @Html.ValidationMessage("ValidTo")
                    </span>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end mt-4">

                    <button type="submit" class="btn btn-primary px-3">
                        Create new post
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function() {

            const form = document.querySelector("form");
            if (!form) return;

            let isDirty = false;

            const fields = form.querySelectorAll("input, textarea, select");

            fields.forEach(el => {
                el.addEventListener("input", () => {
                    isDirty = true;
                });
            });

            form.addEventListener("submit", () => {
                isDirty = false;
            });

            // IMPORTANT: must be returnValue for Chrome/Edge
            window.addEventListener("beforeunload", function(e) {
                if (!isDirty) return;

                e.preventDefault();
                e.returnValue = ""; // triggers browser warning
            });

        });
    </script>
}