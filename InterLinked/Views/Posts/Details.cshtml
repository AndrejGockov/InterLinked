@model InterLinked.Models.Post
@inject UserManager<InterLinked.Models.InterlinkedAppUser> UserManager
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Details";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    var user = User.Identity.IsAuthenticated
        ? await UserManager.GetUserAsync(User)
        : null;

    var isIndividual = user?.organizationType == InterlinkedAppUser.UserType.Personal;
    var isOwner = Model.UserId == userId;

    var alreadyApplied = Model.Applications != null &&
        Model.Applications.Any(a => a.UserId == userId);
}

<style>
    .company-link {
        color: #212529;
        text-decoration: none;
        font-weight: 600;
    }

        .company-link:hover {
            text-decoration: underline;
            color: #0d6efd;
        }

    .external-link {
        color: #6c757d;
        text-decoration: none;
        font-size: 0.95rem;
    }

        .external-link:hover {
            text-decoration: underline;
            color: #0d6efd;
        }
</style>

<style>
    .company-link {
        color: #0d6efd;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
    }

        .company-link:hover {
            text-decoration: underline;
        }
</style>

<div class="container mt-4">

    <!-- POST CARD -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <div class="mb-4">

                <h1 class="fw-bold mb-1">@Model.Title</h1>

                <!-- COMPANY NAME -->
                <a asp-controller="Companies"
                       asp-action="Details"
                       asp-route-id="@Model.UserId"
                       class="company-link">
                    @Model.User?.UserName
                </a>

                <br />

                <!-- WEBSITE -->
                @if (!string.IsNullOrEmpty(Model.WebsiteLink))
                {
                    <a href="@Model.WebsiteLink"
                           target="_blank"
                           class="external-link">
                        Visit post website ↗
                    </a>
                }

            </div>

            <div class="mb-3">
                <span class="badge bg-primary">
                    Posted at: @Model.PostedAt.ToString("dd MMM yyyy")
                </span>

                <span class="badge bg-warning text-dark ms-2">
                    Open until: @(Model.ValidTo?.ToString("dd MMM yyyy") ?? "No expiry date")
                </span>
            </div>

            <hr />

            <h5>Position description:</h5>
            <p style="white-space: pre-line;">
                @Model.Description
            </p>

            <hr />

            <!-- APPLY SECTION -->
            @if (User.Identity.IsAuthenticated && isIndividual && !isOwner)
            {
                if (alreadyApplied)
                {
                    <span class="btn btn-success disabled">
                        Already Applied
                    </span>
                }
                else
                {
                    <a asp-controller="Applications"
                           asp-action="Create"
                           asp-route-postId="@Model.PostId"
                           class="btn btn-primary">
                        Apply Now
                    </a>
                }
            }

        </div>
    </div>

    <!-- ACTION BUTTONS -->
    <div class="mb-3">
        @if (isOwner)
        {
            <div class="d-inline-flex gap-2">
                <a asp-action="Edit"
                       asp-route-id="@Model.PostId"
                       class="btn btn-outline-primary btn-sm">
                    Edit post
                </a>

                <a asp-action="Delete"
                       asp-route-id="@Model.PostId"
                       class="btn btn-outline-danger btn-sm"
                       onclick="return confirm('Are you sure you want to delete this post?');">
                    Delete post
                </a>
            </div>
        }
    </div>

    <!-- APPLICANTS -->
    @if (ViewBag.CanViewApplicants == true)
    {
        <div class="card shadow-sm mt-4">
            <div class="card-body">

                <h4 class="mb-3">Applicants</h4>

                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>CV</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td>@app.User?.UserName</td>
                                <td>@app.User?.Email</td>

                                <td>
                                    @if (!string.IsNullOrEmpty(app.User?.CvPath))
                                    {
                                        <a href="@app.User.CvPath" target="_blank">
                                            View CV
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No CV</span>
                                    }
                                </td>

                                <td>@app.Status</td>

                                <td>
                                    @if (app.Status == ApplicationStatus.Pending)
                                    {
                                        <a asp-controller="Applications"
                                               asp-action="Approve"
                                               asp-route-id="@app.ApplicationId"
                                               class="btn btn-success btn-sm">
                                            Approve
                                        </a>

                                        <a asp-controller="Applications"
                                               asp-action="Reject"
                                               asp-route-id="@app.ApplicationId"
                                               class="btn btn-danger btn-sm">
                                            Reject
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }

</div>