@model IEnumerable<InterLinked.Models.Post>

@{
    ViewData["Title"] = "My Posts";
}

<div class="container-fluid m-5 p-4">

</div>

<div class="row">
    <div class="col-md-6">
        <h1 class="fw-bold mb-2">My Posts</h1>
        <p>View your company's posts</p>
    </div>
    <div class="col-md-6 d-flex flex-column justify-content-end align-items-end">
        <p>
            <a asp-action="Create" class="btn btn-primary fw-bold">Create New Post</a>
        </p>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th><h4 class="fw-bold">Post</h4></th>
            <th><h5 class="fw-bold">Status</h5></th>
            <th><h5 class="fw-bold">Actions</h5></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <div class="container">
                    <div class="row align-items-center">
                        <td class="col-md-7">
                            <div class="">
                                <div class="mb-1 d-flex align-items-baseline">
                                    <h4 class="fw-bold me-2">@item.Title</h4>
                                    <p class="">@item.PostedAt.ToString("dd.MM.yyyy")</p>
                                </div>
                        
                                <div>
                                    <p class="fw-bold fs-6 m-0">Description</p>
                                    <p>
                                        @(item.Description?.Length > 80
                                                ? item.Description.Substring(0, 80) + "..."
                                                : item.Description)
                                    </p>
                                </div>
                            </div>
                        </td>
                        <td class="col-md-2 align-items-baseline">
                            <div class="align-items-baseline">
                                @if (item.IsActive())
                                {
                                    <span class="badge bg-success fs-6">Active Until: @(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Expired on: @(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")</span>
                                }
                            </div>
                        </td>

                        <td class="col-md-3">
                            <div class="align-items-baseline">
                                <a asp-action="Details" asp-route-id="@item.PostId" class="btn btn-secondary">View</a>
                                <a asp-action="Edit" asp-route-id="@item.PostId" class="btn btn-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.PostId" class="btn btn-danger">Delete</a>
                            </div>
                        </td>
                    </div>

                </div>
            </tr>
        }
    </tbody>
</table>