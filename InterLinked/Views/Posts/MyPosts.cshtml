@model IEnumerable<InterLinked.Models.Post>

@{
    ViewData["Title"] = "My Posts";
}

<h1>My Posts</h1>

<p></p>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Post</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Posted At</th>
            <th>Valid To</th>
            <th>Website</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>

                <td>
                    @(item.Description?.Length > 80
                        ? item.Description.Substring(0, 80) + "..."
                        : item.Description)
                </td>

                <td>@item.PostedAt.ToString("yyyy-MM-dd")</td>

                <td>
                    @(item.ValidTo?.ToString("yyyy-MM-dd") ?? "No expiry")
                </td>

                <td>
                    @{
                        var url = item.WebsiteLink;

                        if (!string.IsNullOrEmpty(url) && !url.StartsWith("http"))
                        {
                            url = "https://" + url;
                        }
                    }

                    <a href="@url" target="_blank" rel="noopener noreferrer">
                        @item.WebsiteLink
                    </a>
                </td>

                <td>
                    @if (item.IsActive())
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Expired</span>
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.PostId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.PostId" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.PostId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>