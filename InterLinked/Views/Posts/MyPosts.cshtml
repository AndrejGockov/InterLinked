@model IEnumerable<InterLinked.Models.Post>

@{
    ViewData["Title"] = "My Posts";
}

<div class="row">
    <div class="col-md-6">
        <h1 class="fw-bold mb-2">My Posts</h1>
        <p>Your company's posts, click on a post to view or edit</p>
    </div>
    <div class="col-md-6 d-flex flex-column justify-content-end align-items-end">
        <p>
            <a asp-action="Create" class="btn btn-primary fw-bold">Create New Post</a>
        </p>
    </div>
</div>

<div class="d-flex flex-column gap-3 mt-4">

    @foreach (var item in Model)
    {
        var isActive = item.IsActive();
        var badgeColor = isActive ? "bg-success" : "bg-danger";

        var statusText = isActive
            ? $"Open until: {(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")}"
            : $"Expired on: {(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")}";

        <a asp-action="Details" asp-route-id="@item.PostId"
               class="d-flex align-items-center p-4 border rounded-3 bg-white text-decoration-none text-reset shadow-sm-hover"
               style="transition: all 0.2s ease;"
               onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.08)'; this.style.transform='translateX(4px)'; this.style.borderColor='#adb5bd';"
               onmouseout="this.style.boxShadow=''; this.style.transform='none'; this.style.borderColor='';">

            <div class="flex-grow-1">
                <div class="d-flex align-items-baseline gap-2 mb-1">
                    <h5 class="fw-bold mb-0">@item.Title</h5>
                    <small class="text-muted">@item.PostedAt.ToString("dd.MM.yyyy")</small>
                </div>

                <p class="text-secondary mb-0 small text-truncate" style="max-width: 500px;">
                    @(item.Description?.Length > 100
                        ? item.Description.Substring(0, 100) + "..."
                        : item.Description ?? "No description available.")
                </p>
            </div>

            <div class="ms-4 d-none d-md-block text-end">
                <span class="badge @badgeColor fs-6 py-2 px-3 rounded-2 fw-medium text-wrap">
                    @statusText
                </span>
            </div>
        </a>
    }
</div>