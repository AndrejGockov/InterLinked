@model IEnumerable<InterLinked.Models.Post>

@{
    ViewData["Title"] = "Internships/job Posts";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">Latest Company Posts</h2>
            <p class="text-muted mb-0">Find your next career opportunities on InterLinked</p>
        </div>
        <input type="text" id="searchInput" class="form-control shadow-sm" style="max-width: 350px; border-radius: 8px;" placeholder="Search posts..." />
    </div>

    <div class="d-flex flex-column gap-3" id="postsContainer">
    </div>

    <div class="text-center py-5 d-none" id="noResults">
        <h5 class="text-secondary">No posts found.</h5>
        <p class="text-muted">Try a different search term.</p>
    </div>

    <nav class="mt-5 d-flex justify-content-center" id="paginationNav">
        <ul class="pagination shadow-sm p-1 bg-white rounded border-0" id="pagination"></ul>
    </nav>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 6;
        let allPosts = [];
        let filtered = [];
        let currentPage = 1;

        function formatDate(dateString) {
            if (!dateString) return "Forever";

            const d = new Date(dateString);
            if (isNaN(d.getTime())) return "Forever";

            return d.toLocaleDateString('de-DE'); // dd.MM.yyyy
        }

        function renderPosts() {
            const container = document.getElementById('postsContainer');
            const noResults = document.getElementById('noResults');
            const totalPages = Math.ceil(filtered.length / PAGE_SIZE);

            if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const start = (currentPage - 1) * PAGE_SIZE;
            const pageItems = filtered.slice(start, start + PAGE_SIZE);

            container.innerHTML = '';
            noResults.classList.toggle('d-none', filtered.length > 0);

            pageItems.forEach(p => {
                const badgeColor = p.isActive ? 'bg-success' : 'bg-danger';

                let statusText;
                if (p.isActive) {
                    statusText = p.validTo
                        ? `Applications open until: ${formatDate(p.validTo)}`
                        : `Open (Forever)`;
                } else {
                    statusText = p.validTo
                        ? `Expired on: ${formatDate(p.validTo)}`
                        : `Expired`;
                }

                const row = document.createElement('a');
                row.href = `/Posts/Details/${p.id}`;
                row.className = 'd-flex align-items-center p-4 border rounded-3 bg-white text-decoration-none text-reset shadow-sm-hover transition-all';
                row.style.transition = "all 0.2s ease";

                row.onmouseover = () => {
                    row.style.boxShadow = "0 4px 12px rgba(0,0,0,0.08)";
                    row.style.transform = "translateX(4px)";
                    row.style.borderColor = "#adb5bd";
                };
                row.onmouseout = () => {
                    row.style.boxShadow = "";
                    row.style.transform = "none";
                    row.style.borderColor = "";
                };

                row.innerHTML = `
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-baseline gap-2 mb-1">
                                <h5 class="fw-bold mb-0">${p.title}</h5>
                                <small class="text-muted">${p.postedAt}</small>
                            </div>
                            <div class="text-primary small mb-1 fw-bold">${p.companyName}</div>
                            <p class="text-secondary mb-0 small text-truncate" style="max-width: 500px;">
                                ${p.description || 'No description available.'}
                            </p>
                        </div>

                        <div class="ms-4 d-none d-md-block text-end">
                            <span class="badge ${badgeColor} fs-6 py-2 px-3 rounded-2 fw-medium text-wrap">
                                ${statusText}
                            </span>
                        </div>
                    `;

                container.appendChild(row);
            });

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            const ul = document.getElementById('pagination');
            ul.innerHTML = '';
            const safeTotalPages = totalPages < 1 ? 1 : totalPages;

            const createPageItem = (label, targetPage, isCurrent, isDisabled) => {
                const li = document.createElement('li');
                li.className = `page-item mx-1 ${isCurrent ? 'active' : ''} ${isDisabled ? 'disabled' : ''}`;
            
                const a = document.createElement('a');
                a.className = `page-link border-0 rounded-2 ${isCurrent ? 'bg-dark text-white' : 'text-dark'}`;
                a.href = 'javascript:void(0)';
                a.innerHTML = label;
            
                if (!isDisabled && !isCurrent) {
                    a.onclick = () => {
                        currentPage = targetPage;
                        renderPosts();
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    };
                }
                li.appendChild(a);
                return li;
            };

            ul.appendChild(createPageItem('&laquo;', 1, false, currentPage === 1));
            ul.appendChild(createPageItem('<', currentPage - 1, false, currentPage === 1));

            if (filtered.length > 0) {
                let start = Math.max(1, currentPage - 2);
                let end = Math.min(safeTotalPages, currentPage + 2);
                for (let i = start; i <= end; i++) {
                    ul.appendChild(createPageItem(i, i, i === currentPage, false));
                }
            } else {
                ul.appendChild(createPageItem('1', 1, true, true));
            }

            ul.appendChild(createPageItem('>', currentPage + 1, false, currentPage === safeTotalPages));
            ul.appendChild(createPageItem('&raquo;', safeTotalPages, false, currentPage === safeTotalPages));
        }

        async function loadPosts() {
            try {
                const res = await fetch('/Posts/GetPostsJson');
                const json = await res.json();
                allPosts = json.data || [];

                const urlParams = new URLSearchParams(window.location.search);
                const searchQ = urlParams.get('search');

                if (searchQ) {
                    document.getElementById('searchInput').value = searchQ;
                    const q = searchQ.toLowerCase();
                    filtered = allPosts.filter(p =>
                        (p.title || '').toLowerCase().includes(q) ||
                        (p.companyName || '').toLowerCase().includes(q)
                    );
                } else {
                    filtered = [...allPosts];
                }

                renderPosts();

            } catch (err) {
                console.error("Error:", err);
            }
        }

        document.getElementById('searchInput').addEventListener('input', function() {
            const q = this.value.toLowerCase();
            filtered = allPosts.filter(p =>
                (p.title || '').toLowerCase().includes(q) ||
                (p.companyName || '').toLowerCase().includes(q)
            );
            currentPage = 1;
            renderPosts();
        });

        loadPosts();
    </script>
}