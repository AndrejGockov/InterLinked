@using Microsoft.AspNetCore.Identity
@inject SignInManager<InterlinkedAppUser> SignInManager
@inject UserManager<InterlinkedAppUser> UserManager

@{
    ViewData["Title"] = "Home Page";
}

<div class="p-5 text-center">
    <div class="pt-5 pb-3">
        @if (SignInManager.IsSignedIn(User))
        {
            var user = await UserManager.GetUserAsync(User);
            <p class="fs-4 mb-2">Welcome, <strong>@user.UserName</strong></p>
        }

        <p class="fs-4">Discover new oppportunities on</p>
        <h1 class="fw-bold display-1">InterLinked</h1>
    </div>

    <div id="searchContainer"
         class="d-flex justify-content-center align-items-center gap-2 border rounded-3 p-4 pe-5 ps-5 bg-white"
         style="transition: all 0.2s ease; max-width: 600px; margin: 0 auto;">
        
        <input type="text" id="mainSearchInput"
               class="p-2 form-control shadow-sm" style="max-width: 350px; border-radius: 8px;"
               placeholder="Job title, post, keywords..." />

        <button id="searchBtn" class="btn btn-primary fw-bold fs-5 d-inline-flex align-items-center">
            Search >>
        </button>
    </div>

    <div id="errorBox" class="d-none w-50 mx-auto mt-5">
        <div class="alert alert-danger py-2 shadow-sm fw-bold mt-3 p-4 pe-5 ps-5" role="alert">
            Enter a valid search
        </div>
    </div>

    <div class="mt-1 pt-5 pb-3">
        @if (!SignInManager.IsSignedIn(User))
        {
            <p class="fs-5 mb-2">Create an account or sign in to see new job posts</p>

            <button class="btn btn-primary ps-3 pe-3 fw-bold fs-5">
                <a class="nav-link text-dark text-white" asp-area="Identity" asp-page="/Account/Register">
                    Get Started
                </a>
            </button>
        }
    </div>
</div>

@section Scripts {
    <script>
        const container = document.getElementById('searchContainer');
        const input = document.getElementById('mainSearchInput');
        const btn = document.getElementById('searchBtn');
        const errorBox = document.getElementById('errorBox');

        // Logic to show/hide using Bootstrap classes
        function doSearch() {
            const query = input.value.trim();

            if (query === "") {
                // Remove 'd-none' (hide) and add 'd-block' (show)
                errorBox.classList.remove('d-none');
                errorBox.classList.add('d-block');
                return;
            }

            // Reverse classes if valid
            errorBox.classList.add('d-none');
            errorBox.classList.remove('d-block');
            window.location.href = `/Posts?search=${encodeURIComponent(query)}`;
        }

        // Hide error when user starts typing
        input.addEventListener('input', () => {
            if (input.value.trim() !== "") {
                errorBox.classList.add('d-none');
                errorBox.classList.remove('d-block');
            }
        });

        // Hover Effect
        container.onmouseover = () => {
            container.style.boxShadow = "0 4px 12px rgba(0,0,0,0.08)";
            container.style.transform = "translateY(-4px)";
            container.style.borderColor = "#adb5bd";
        };
        container.onmouseout = () => {
            container.style.boxShadow = "";
            container.style.transform = "none";
            container.style.borderColor = "";
        };

        btn.addEventListener('click', doSearch);
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') doSearch(); });
    </script>
}