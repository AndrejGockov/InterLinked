@model IEnumerable<InterLinked.Models.Post>

@{
    ViewData["Title"] = "Home Page";
}

<div class="row">
    <div class="col-md-3">
        @* Explore Section *@
        <div class="p-3">
            <ul class="nav flex-column">
        
                <li class="nav-item">
                    <span class="text-muted fw-bold ps-3 mb-2 d-block">
                        Explore
                    </span>
                </li>

                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" 
                           asp-area="" asp-controller="Home" asp-action="Index">
                        @* <i class="bi bi-house me-3 fs-5"></i> *@
                        <button class="btn btn-sm btn-outline-primary">
                            Home
                        </button>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10"
                           asp-area="" asp-controller="Posts" asp-action="Index">
                        @* <i class="bi bi-arrow-up-right-circle me-3 fs-5"></i> *@
                        <button class="btn btn-sm btn-outline-primary">
                            Posts
                        </button>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10"
                           asp-area="" asp-controller="Posts" asp-action="Index">
                        @* <i class="bi bi-arrow-up-right-circle me-3 fs-5"></i> *@
                        <button class="btn btn-sm btn-outline-primary">
                            More Opportunities
                        </button>
                    </a>
                </li>
                
                @* TODO: *@
                @* ROUTE DOESNT EXIST CREATE COMPANY VIEW *@
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" 
                           asp-area="" asp-controller="Companies" asp-action="Companies">
                        @* <i class="bi bi-arrow-up-right-circle me-3 fs-5"></i>  *@
                        <button class="btn btn-sm btn-outline-primary">
                            Companies
                        </button>
                    </a>
                </li>

                <li class="nav-item mt-4">
                    <span class="text-muted fw-bold ps-3 mb-2 d-block">
                        Profile
                    </span>
                </li>

                <li class="nav-item">
                        @if (User.IsInRole("Company") || User.IsInRole("StudentOrganization"))
                        {
                        <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" asp-area="" asp-controller="Posts" asp-action="MyPosts">
                            <button class="btn btn-sm btn-outline-primary">
                                My Posts
                            </button>
                        </a>
                            
                        <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" asp-area="" asp-controller="Posts" asp-action="Create">
                            <button class="btn btn-sm btn-outline-primary">
                                Create New Post
                            </button>
                        </a>
                        }
                        else if (User.IsInRole("Individual"))
                        {
                        <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" asp-area="" asp-controller="Applications" asp-action="MyApplications">
                            <button class="btn btn-sm btn-outline-primary">
                                My Applications
                            </button>
                        </a>
                        }
                        else
                        {
                            <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" asp-area="Identity" asp-page="/Account/Register">
                            <button class="btn btn-sm  btn-outline-primary">
                                    Register
                                </button>
                            </a>
                            <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" asp-area="Identity" asp-page="/Account/Login">
                                <button class="btn btn-sm  btn-primary">
                                    Login
                                </button>
                            </a>
                        }
                </li>

                <li class="nav-item mt-4">
                    <span class="text-muted fw-bold ps-3 mb-2 d-block">
                        Tools
                    </span>
                </li>


                @* TODO: *@
                @* IF WE MAKE PAGE *@
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center py-2 px-3 rounded-3 bg-opacity-10" 
                           asp-area="" asp-controller="Home" asp-action="Index">
                        @* <i class="bi bi-newspaper me-3 fs-5"></i>  *@
                        <button class="btn btn-sm btn-outline-primary">
                            AI Assistant
                        </button>
                    </a>
                </li>
            </ul>
        </div>
    </div>

    @* Middle Section*@
    <div class="col-md-7">

        @* TODO *@
        @* Replace with list of latest posts *@
        <div class="text-center">
            <h2 class="display-4">Welcome to Linker!</h2>
            <h5>Currently active posts</h5>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th><h4 class="fw-bold">Post</h4></th>
                    <th><h5 class="fw-bold">Active Until</h5></th>

                   
                   <th><h5 class="fw-bold">Info</h5></th>
                   
                    @if (User.IsInRole("Individual"))
                    {
                        <th><h5 class="fw-bold">Apply</h5></th>
                    }
            
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <div class="container">
                            <div class="row align-items-center">
                                <td class="col-md-10">
                                    <div class="">
                                        <div class="mb-1 d-flex align-items-baseline">
                                            <h4 class="fw-bold me-2">@item.Title</h4>
                                            <p class="text-muted m-0">Company: @(item.User.UserName) at @item.PostedAt.ToString("dd.MM.yyyy")</p>
                                        </div>
                                        <div>
                                            <p>
                                                @(item.Description?.Length > 80
                                                        ? item.Description.Substring(0, 80) + "..."
                                                        : item.Description)
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="col-md-2 align-items-baseline">
                                    <div class="align-items-baseline">
                                        @if (item.IsActive())
                                        {
                                            <span class="badge bg-success fs-6">@(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger fs-6">Expired on: @(item.ValidTo?.ToString("dd.MM.yyyy") ?? "No Expiration")</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                   <a class="btn btn-primary btn-sm fw-bold" asp-controller="Posts" asp-action="details" asp-route-id="@item.PostId">View</a><br />
                                </td>
                                <td>
                                    @if (User.IsInRole("Individual"))
                                    {
                                        <a class="btn btn-primary btn-sm fw-bold" asp-controller="Applications" asp-action="Create" asp-route-postId="@item.PostId">Apply</a>
                                    }
                                </td>
                            </div>
                        </div>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Profile Section *@
    <div class="col-md-2">
        @if (Model != null)
        {
            <div class="card p-2 shadow-sm">
                <p class="mb-1 text-muted small">Logged in as:</p>
                <p class="fw-bold">@User.Identity?.Name</p>
                @* You can add more profile details here since Model is the full InterlinkedAppUser *@
            </div>
        }
        else
        {
            <div class="alert alert-info py-2 small">
                Please <a asp-area="Identity" asp-page="/Account/Login">Login</a> to see your profile.
            </div>
        }
    </div>
</div>