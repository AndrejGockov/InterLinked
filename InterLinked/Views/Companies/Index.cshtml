@{
    ViewData["Title"] = "Registered Companies";
}

<style>
    .companies-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1.5rem;
    }

    @@media (max-width: 768px) {
        .companies-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .companies-grid {
            grid-template-columns: 1fr;
        }
    }

    .company-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 2.5rem 1.5rem;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.18s ease, transform 0.18s ease, border-color 0.18s ease;
    }

        .company-card:hover {
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            transform: translateY(-3px);
            border-color: #c0c0c0;
            color: inherit;
            text-decoration: none;
        }

    .company-avatar {
        width: 96px;
        height: 96px;
        border-radius: 18px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        font-weight: 700;
        color: #374151;
        letter-spacing: -1px;
        flex-shrink: 0;
        overflow: hidden;
    }

        .company-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .company-name {
        font-size: 1.1rem;
        font-weight: 600;
        text-align: center;
        color: #111827;
        line-height: 1.3;
        word-break: break-word;
    }

    #searchInput {
        max-width: 320px;
    }

    .no-results {
        display: none;
        color: #6b7280;
        font-size: 0.95rem;
    }

    .pagination .page-link {
        color: #374151;
    }

    .pagination .page-item.active .page-link {
        background-color: #374151;
        border-color: #374151;
        color: #fff;
    }

    .pagination .page-item.disabled .page-link {
        color: #9ca3af;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h2 class="fw-bold mb-0">Registered Companies</h2>
        <input type="text" id="searchInput" class="form-control" placeholder="Search companies..." />
    </div>

    <div class="companies-grid" id="companiesGrid"></div>

    <p class="no-results mt-4" id="noResults">No companies found.</p>

    <nav class="mt-4 d-flex justify-content-center" id="paginationNav" style="display:none!important">
        <ul class="pagination" id="pagination"></ul>
    </nav>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 12;
        let allCompanies = [];
        let filtered = [];
        let currentPage = 1;

        function getInitials(name) {
            if (!name) return '?';
            return name.split(/\s+/).map(w => w[0]).join('').substring(0, 2).toUpperCase();
        }

        function renderCards() {
            const grid = document.getElementById('companiesGrid');
            const noResults = document.getElementById('noResults');
            const paginationNav = document.getElementById('paginationNav');

            const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
            if (currentPage > totalPages) currentPage = 1;

            const start = (currentPage - 1) * PAGE_SIZE;
            const pageItems = filtered.slice(start, start + PAGE_SIZE);

            grid.innerHTML = '';

            if (filtered.length === 0) {
                noResults.style.display = 'block';
                paginationNav.style.display = 'none';
                return;
            }

            noResults.style.display = 'none';
            paginationNav.style.display = 'flex';

            pageItems.forEach(c => {
                const card = document.createElement('a');
                card.href = `/Companies/Details/${c.id}`;
                card.className = 'company-card';

                const avatarHtml = c.profilePicturePath
                    ? `<img src="${c.profilePicturePath}" alt="${c.userName}" />`
                    : getInitials(c.userName);

                card.innerHTML = `
                            <div class="company-avatar">${avatarHtml}</div>
                            <div class="company-name">${c.userName ?? 'Unknown'}</div>
                        `;
                grid.appendChild(card);
            });

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            const ul = document.getElementById('pagination');
            ul.innerHTML = '';

            const prev = document.createElement('li');
            prev.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
            prev.innerHTML = `<a class="page-link" href="#">&laquo;</a>`;
            prev.addEventListener('click', e => { e.preventDefault(); if (currentPage > 1) { currentPage--; renderCards(); } });
            ul.appendChild(prev);

            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement('li');
                li.className = `page-item ${i === currentPage ? 'active' : ''}`;
                li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                li.addEventListener('click', e => { e.preventDefault(); currentPage = i; renderCards(); });
                ul.appendChild(li);
            }

            const next = document.createElement('li');
            next.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
            next.innerHTML = `<a class="page-link" href="#">&raquo;</a>`;
            next.addEventListener('click', e => { e.preventDefault(); if (currentPage < totalPages) { currentPage++; renderCards(); } });
            ul.appendChild(next);
        }

        async function loadCompanies() {
            const res = await fetch('/Companies/GetCompaniesJson');
            const json = await res.json();
            allCompanies = json.data;
            filtered = allCompanies;
            renderCards();
        }

        document.getElementById('searchInput').addEventListener('input', function() {
            const q = this.value.toLowerCase();
            filtered = allCompanies.filter(c => (c.userName ?? '').toLowerCase().includes(q));
            currentPage = 1;
            renderCards();
        });

        loadCompanies();
    </script>
}
